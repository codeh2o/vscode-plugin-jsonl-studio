{
  "name": "clipboard-format-preview",
  "displayName": "Clipboard Format Preview",
  "description": "Open copied text as a collapsible JSON tree or escaped newline preview beside the editor.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:selection-format-preview.openBeside"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "selection-format-preview.openBeside",
        "title": "Open Clipboard Format Preview",
        "icon": "media/preview-format-title.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "selection-format-preview.openBeside",
          "group": "navigation@100"
        }
      ],
      "commandPalette": [
        {
          "command": "selection-format-preview.openBeside",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.5"
  }
}
