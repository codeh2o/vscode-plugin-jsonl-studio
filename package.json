{
  "name": "selection-format-preview",
  "displayName": "Format Preview",
  "description": "Paste text into a bottom panel and preview formatted JSON or escaped newline Markdown.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:selection-format-preview-format-view"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "selection-format-preview-format-container",
          "title": "PREVIEW FORMAT",
          "icon": "media/preview-format.svg"
        }
      ]
    },
    "views": {
      "selection-format-preview-format-container": [
        {
          "id": "selection-format-preview-format-view",
          "name": "PREVIEW FORMAT",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.5"
  }
}
