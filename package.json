{
  "name": "clipboard-format-preview",
  "displayName": "JSONL Format Preview",
  "description": "Open JSONL and NDJSON files in a side-by-side editable formatted preview.",
  "version": "0.0.1",
  "publisher": "landz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeh2o/Clipboard-Format-Preview.git"
  },
  "bugs": {
    "url": "https://github.com/codeh2o/Clipboard-Format-Preview/issues"
  },
  "homepage": "https://github.com/codeh2o/Clipboard-Format-Preview#readme",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:clipboard-format-preview.openJsonlPreview"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clipboard-format-preview.openJsonlPreview",
        "title": "Open JSONL Format Preview",
        "icon": "media/preview-format-title.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "clipboard-format-preview.openJsonlPreview",
          "when": "resourceExtname == .jsonl || resourceExtname == .ndjson",
          "group": "navigation@100"
        }
      ],
      "commandPalette": [
        {
          "command": "clipboard-format-preview.openJsonlPreview",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run clean && npm run compile && node --test out/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.4.5"
  }
}
